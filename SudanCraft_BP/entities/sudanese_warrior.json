{
    "format_version": "1.20.0",
    "minecraft:entity": {
        "description": {
            "identifier": "sudancraft:sudanese_warrior",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false
        },
        "components": {
            "minecraft:type_family": {
                "family": ["human", "warrior", "sudan", "friendly"]
            },
            "minecraft:collision_box": {
                "width": 0.6,
                "height": 1.8
            },
            "minecraft:health": {
                "value": 40,
                "max": 40
            },
            "minecraft:attack": {
                "damage": 7
            },
            "minecraft:movement": {
                "value": 0.28
            },
            "minecraft:navigation.walk": {
                "can_path_over_water": true,
                "avoid_water": false
            },
            "minecraft:movement.basic": {},
            "minecraft:behavior.hurt_by_target": {
                "priority": 1
            },
            "minecraft:behavior.nearest_attackable_target": {
                "priority": 2,
                "within_radius": 20,
                "entity_types": [
                    {
                        "filters": {
                            "test": "is_family",
                            "subject": "other",
                            "value": "monster"
                        },
                        "max_dist": 20
                    }
                ]
            },
            "minecraft:behavior.melee_attack": {
                "priority": 3,
                "speed_multiplier": 1.2,
                "track_target": true
            },
            "minecraft:behavior.random_stroll": {
                "priority": 6,
                "speed_multiplier": 0.9
            },
            "minecraft:behavior.look_at_player": {
                "priority": 7,
                "look_distance": 8
            },
            "minecraft:equipment": {
                "table": "loot_tables/entities/sudanese_warrior_gear.json",
                "slot_drop_chance": [
                    {
                        "slot": "slot.weapon.mainhand",
                        "drop_chance": 0.5
                    }
                ]
            },
            "minecraft:loot": {
                "table": "loot_tables/entities/sudanese_warrior.json"
            },
            "minecraft:physics": {},
            "minecraft:pushable": {
                "is_pushable": true,
                "is_pushable_by_piston": true
            },
            "minecraft:interaction": {
                "interactions": [
                    {
                        "on_interact": {
                            "filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    },
                                    {
                                        "test": "has_equipment",
                                        "subject": "other",
                                        "domain": "hand",
                                        "value": "sudancraft:gold_nugget_sudan"
                                    }
                                ]
                            },
                            "event": "sudancraft:trade",
                            "target": "self"
                        },
                        "use_item": true,
                        "interact_text": "Trade"
                    }
                ]
            }
        },
        "events": {
            "sudancraft:trade": {
                "run_command": {
                    "command": [
                        "give @p sudancraft:nile_spear 1",
                        "say §6المحارب السوداني: شكراً لك! إليك رمح النيل."
                    ]
                }
            }
        }
    }
}
